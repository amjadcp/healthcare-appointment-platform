{"openapi":"3.0.1","info":{"title":"Healthcare Appointment Platform API","description":"REST API documentation for the Healthcare Appointment Platform.","version":"1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"security":[{"Bearer Authentication":[]}],"tags":[{"name":"Appointment Management","description":"Endpoints for booking, slots, auditing, and RabbitMQ DLQ management"},{"name":"Authentication","description":"Endpoints for administrator registration and user login"},{"name":"Doctor Management","description":"Endpoints for doctor provisioning and availability management"}],"paths":{"/api/v1/doctors/{id}/availability":{"get":{"tags":["Doctor Management"],"summary":"Get Doctor Availability Schedule","description":"Retrieves the weekly availability schedule for the specified doctor ID.","operationId":"getDoctorAvailability","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Availability schedule retrieved successfully","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}},"400":{"description":"User is not a doctor","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}},"404":{"description":"Doctor not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}}}},"put":{"tags":["Doctor Management"],"summary":"Update Doctor Availability (Admin only)","description":"Clears the old availability schedule for the given doctor ID and saves the new list of day-wise schedules.","operationId":"updateAvailability","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/AvailabilityUpdateRequest"}}}},"required":true},"responses":{"200":{"description":"Availability successfully updated","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}},"400":{"description":"Invalid times or malformed request","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}},"403":{"description":"Access denied","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}},"404":{"description":"Doctor not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/DoctorAvailabilityResponse"}}}}}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/events/dlq/reprocess":{"post":{"tags":["Appointment Management"],"summary":"Reprocess message(s) from DLQ (Admin only)","description":"Republishes a failed event (by eventId) back to the main exchange, or reprocesses all messages in the DLQ if no ID is specified.","operationId":"reprocessDlqMessages","parameters":[{"name":"eventId","in":"query","description":"Optional eventId of a specific message to reprocess","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"Messages reprocessed successfully"},"403":{"description":"Requires Admin permissions"},"404":{"description":"Specific message ID not found in the DLQ"}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/events/dlq/dismiss":{"post":{"tags":["Appointment Management"],"summary":"Dismiss/Purge message(s) from DLQ (Admin only)","description":"Discards a specific message from the DLQ by eventId, or purges all DLQ messages if no ID is specified.","operationId":"dismissDlqMessages","parameters":[{"name":"eventId","in":"query","description":"Optional eventId of a specific message to dismiss","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"Messages dismissed successfully"},"403":{"description":"Requires Admin permissions"},"404":{"description":"Specific message ID not found in the DLQ"}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/doctors":{"get":{"tags":["Doctor Management"],"summary":"Get all Doctors","description":"Retrieves a list of all doctors. Can be filtered by organization slug. If orgSlug is omitted and the user is authenticated, it defaults to the user's organization.","operationId":"getAllDoctors","parameters":[{"name":"orgSlug","in":"query","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"List of doctors retrieved successfully","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/UserResponse"}}}}}}},"post":{"tags":["Doctor Management"],"summary":"Provision a new Doctor (Admin only)","description":"Registers a new doctor user associated with the authenticated admin's organization. Automatically provisions a default 9 AM to 5 PM weekly availability schedule.","operationId":"provisionDoctor","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DoctorProvisionRequest"}}},"required":true},"responses":{"201":{"description":"Doctor successfully provisioned","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"400":{"description":"Invalid request or malformed payload","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"401":{"description":"User is not authenticated or not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"403":{"description":"Insufficient permissions (requires ADMIN role)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"409":{"description":"Doctor email is already in use","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/auth/register":{"post":{"tags":["Authentication"],"summary":"Register a new Administrator","description":"Creates a new organization and registers the user as the initial administrator. Returns a JWT auth token upon successful registration.","operationId":"registerAdmin","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RegisterRequest"}}},"required":true},"responses":{"201":{"description":"Administrator and organization successfully registered","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}},"400":{"description":"Invalid request parameters or malformed JSON","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}},"409":{"description":"Email or organization name/slug is already in use","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}}}}},"/api/v1/auth/login":{"post":{"tags":["Authentication"],"summary":"Authenticate user","description":"Validates user credentials (email and password) and returns a JWT authentication token upon success.","operationId":"login","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/LoginRequest"}}},"required":true},"responses":{"200":{"description":"Successfully authenticated","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}},"400":{"description":"Invalid request parameters","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}},"401":{"description":"Invalid email or password","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AuthResponse"}}}}}}},"/api/v1/appointments":{"get":{"tags":["Appointment Management"],"summary":"Get Paginated Appointments (Authenticated)","description":"Retrieves a paginated list of appointments. Admins see all appointments within their organization, while Doctors see only their own appointments.","operationId":"getAppointments","parameters":[{"name":"pageable","in":"query","required":true,"schema":{"$ref":"#/components/schemas/Pageable"}}],"responses":{"200":{"description":"Appointments page retrieved successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PageAppointmentResponse"}}}},"401":{"description":"User is not authenticated","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PageAppointmentResponse"}}}}},"security":[{"Bearer Authentication":[]}]},"post":{"tags":["Appointment Management"],"summary":"Book an Appointment","description":"Performs an atomic, immediate booking flow: reserves the selected doctor availability slot and instantly confirms payment.","operationId":"bookAppointment","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AppointmentRequest"}}},"required":true},"responses":{"201":{"description":"Appointment successfully booked","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"400":{"description":"Invalid time, unaligned boundary, past slot, or user is not a doctor","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"409":{"description":"Slot is already booked or temporarily held for payment","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}}}}},"/api/v1/appointments/{id}/release":{"post":{"tags":["Appointment Management"],"summary":"Release a Reservation","description":"Manually cancels and deletes a PENDING_PAYMENT reservation, returning the slot immediately to availability.","operationId":"releaseAppointmentReservation","parameters":[{"name":"id","in":"path","description":"ID of the appointment reservation to release","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"204":{"description":"Reservation successfully released"},"400":{"description":"Appointment is not in PENDING_PAYMENT status"}}}},"/api/v1/appointments/{id}/confirm-payment":{"post":{"tags":["Appointment Management"],"summary":"Confirm Appointment Payment","description":"Finalizes the booking by confirming payment for a temporarily held reservation. Transitions status to CONFIRMED.","operationId":"confirmAppointmentPayment","parameters":[{"name":"id","in":"path","description":"ID of the temporary appointment reservation","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Payment confirmed; appointment booked","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"400":{"description":"Appointment is not in PENDING_PAYMENT status","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"404":{"description":"Reservation not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"409":{"description":"Reservation has expired and was auto-deleted","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}}}}},"/api/v1/appointments/{id}/complete":{"post":{"tags":["Appointment Management"],"summary":"Complete an Appointment (Authenticated)","description":"Marks a confirmed appointment as COMPLETED. Can be invoked by the system or doctors/admins.","operationId":"completeAppointment","parameters":[{"name":"id","in":"path","description":"ID of the confirmed appointment","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"204":{"description":"Appointment marked as completed"},"400":{"description":"Only CONFIRMED appointments can be marked as COMPLETED"},"404":{"description":"Appointment not found"}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/appointments/reserve":{"post":{"tags":["Appointment Management"],"summary":"Reserve an Appointment Slot (2-Step Flow)","description":"Creates a temporary reservation (30-second hold) for the selected slot, allowing the patient to proceed to payment.","operationId":"reserveAppointment","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AppointmentRequest"}}},"required":true},"responses":{"201":{"description":"Slot successfully reserved","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"400":{"description":"Invalid slots or request format","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}},"409":{"description":"Slot is already booked or temporarily held","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AppointmentResponse"}}}}}}},"/api/v1/slots/available":{"get":{"tags":["Appointment Management"],"summary":"Get Doctor Available Slots","description":"Retrieves all 30-minute time slots for a doctor on a specific date, indicating whether they are AVAILABLE, PAST, or already booked.","operationId":"getAvailableSlots","parameters":[{"name":"doctorId","in":"query","description":"ID of the doctor","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"date","in":"query","description":"Date in ISO-8601 format (YYYY-MM-DD)","required":true,"schema":{"type":"string","format":"date"}}],"responses":{"200":{"description":"Available slots retrieved successfully","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/SlotResponse"}}}}},"400":{"description":"User is not a doctor","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/SlotResponse"}}}}},"404":{"description":"Doctor not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/SlotResponse"}}}}}}}},"/api/v1/logs":{"get":{"tags":["Appointment Management"],"summary":"Get Business Audit Trail (Admin only)","description":"Retrieves a detailed audit log of appointment state transitions (e.g. from PENDING_PAYMENT to CONFIRMED).","operationId":"getAppointmentLogs","parameters":[{"name":"pageable","in":"query","required":true,"schema":{"$ref":"#/components/schemas/Pageable"}}],"responses":{"200":{"description":"Audit trail logs retrieved successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PageAppointmentLogResponse"}}}},"403":{"description":"Requires Admin permissions","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PageAppointmentLogResponse"}}}}},"security":[{"Bearer Authentication":[]}]}},"/api/v1/events":{"get":{"tags":["Appointment Management"],"summary":"Get Audit